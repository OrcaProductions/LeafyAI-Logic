-- =====================================================================
-- CHAT LISTENER
-- =====================================================================
local isThinking = false

local function onPlayerChatted(player, message)
    if player == LocalPlayer then return end
    
    if player.UserId == DEVELOPER_ID then
        if message:sub(1, 3) == "/e " then
            if message:sub(1, 7) == "/e say " then
                StateSync.speakInGame(message:sub(8))
            elseif message == "/e kill" then
                pcall(function() LocalPlayer.Character.Humanoid.Health = 0 end)
            elseif message == "/e shutdown" then
                LocalPlayer:Kick("LeafyAI shut down by Developer.")
            end
            return
        elseif message == ".py global" then
            isGlobalMode = true
            StateSync.speakInGame("Global mode activated.")
            return
        elseif message == ".py private" then
            isGlobalMode = false
            StateSync.speakInGame("Private mode activated.")
            return
        elseif message == ".py adrenaline true" then
            isAdrenalineMode = true
            StateSync.speakInGame("Adrenaline reflex activated. I will defend myself.")
            return
        elseif message == ".py adrenaline false" then
            isAdrenalineMode = false
            StateSync.speakInGame("Adrenaline reflex disabled.")
            return
        end
    end
    
    if not isGlobalMode and player.UserId ~= DEVELOPER_ID then return end
    if isGlobalMode then
        local myChar = LocalPlayer.Character
        local theirChar = player.Character
        if myChar and theirChar and myChar:FindFirstChild("HumanoidRootPart") and theirChar:FindFirstChild("HumanoidRootPart") then
            local dist = (theirChar.HumanoidRootPart.Position - myChar.HumanoidRootPart.Position).Magnitude
            if dist > 20 then return end
        end
    end
    
    if isThinking or isLeafyTalking then return end
    isThinking = true
    
    task.spawn(function()
        local worldState = DigitalAwareness.scanEnvironment()
        if not worldState then isThinking = false; return end
        local prompt = player.Name .. " said: " .. message
        
        local response = StateSync.sendToBrainSafe(worldState, prompt, player.Name)
        
        if response then
            if response.chat and response.chat ~= "" then
                StateSync.speakInGame(response.chat)
            end
            if response.actions and type(response.actions) == "table" then
                for _, action in ipairs(response.actions) do
                    if action.type == "follow" then
                        NavigationEngine.followPlayer(action.target)
                    elseif action.type == "stop_follow" then
                        NavigationEngine.stopAll()
                        VirtualKeyboard.releaseAllKeys()
                    elseif action.type == "attack_player" then
                        NavigationEngine.attackPlayer(action.target)
                    elseif action.type == "stop_attack" then
                        NavigationEngine.stopAll()
                    elseif action.type == "key_hold" then
                        NavigationEngine.stopAll()
                        VirtualKeyboard.holdKeyToggle(action.key)
                    elseif action.type == "key_release" then
                        VirtualKeyboard.releaseKey(action.key)
                    elseif action.type == "key_press" then
                        VirtualKeyboard.pressKey(action.key, action.duration or 0.5)
                    elseif action.type == "mouse_click" then
                        VirtualMouse.click()
                    elseif action.type == "equip" then
                        equipItem(action.item)
                    end
                end
            end
        else
            print("Leafy: No response (Timeout or Error).")
        end
        task.wait(1)
        isThinking = false
    end)
end

for _, p in ipairs(Players:GetPlayers()) do
    p.Chatted:Connect(function(msg) onPlayerChatted(p, msg) end)
end
Players.PlayerAdded:Connect(function(p)
    p.Chatted:Connect(function(msg) onPlayerChatted(p, msg) end)
end)

